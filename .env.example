# Configuration template. Pick the right scenario and copy:
#
#   cp .env.example .env             # standalone (Quickstart)
#   docker compose up --build
#
# Or anpr as one service in a bigger compose stack (next to mosquitto,
# Frigate, Home Assistant on the same docker network):
#
#   cp .env.example .env.compose     # then flip the values noted inline
#   docker compose --env-file .env.compose up -d --build

# ---------- MQTT (required) ----------
# Standalone:    LAN IP/hostname of the broker (e.g. 192.168.x.x)
# Compose stack: container name on the shared network — typically `mosquitto`
MQTT_HOST=<broker-host>
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# ---------- Frigate ingest ----------
# We subscribe to Frigate's `frigate/events` topic and act on `type=end`
# events with a recognised plate — same data the Frigate UI shows under
# "Recognized License Plate" (consolidated best reading per object track).
FRIGATE_TOPIC=frigate/events
# Minimum LPR confidence (0.0–1.0) Frigate must report before we record the
# sighting. Lower = more sightings + more OCR noise; higher = fewer false
# reads but you may miss plates Frigate isn't sure about.
MIN_SCORE=0.8
# Default page size for the dashboard's plates table. Bump if you have lots
# of plates and prefer fewer Prev/Next clicks; hard cap is 1000 server-side.
PAGE_SIZE=50

# ---------- Frigate snapshots + deep-link (optional) ----------
# FRIGATE_URL: backend → Frigate HTTP API. Empty disables snapshot capture.
#   <frigate-host>: address the anpr backend reaches Frigate on.
#   Standalone:    LAN IP/hostname    → e.g. http://192.168.x.x:5000
#   Compose stack: container name    → http://frigate:5000
FRIGATE_URL=http://<frigate-host>:5000

# FRIGATE_PUBLIC_URL: browser → Frigate UI deep-link. Falls back to
# FRIGATE_URL when empty.
#   <frigate-public-host>: address the operator's BROWSER reaches Frigate
#   on. NOT the container name — browsers aren't on the docker network.
#   Always a LAN IP / hostname / reverse-proxy URL (e.g. 192.168.x.x).
FRIGATE_PUBLIC_URL=http://<frigate-public-host>:5000
